{
  "name": "pokemmocompendium",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://pokemmo-compendium.web.app/",
  "scripts": {
    "dev": "vite",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "preview": "vite preview",
    "format": "prettier --write --cache \"**/*.{ts,tsx,js,jsx,css,json,md}\"",
    "format:check": "prettier --check --cache \"**/*.{ts,tsx,js,jsx,css,json,md}\"",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "lint:style": "stylelint \"src/**/*.css\" --cache",
    "lint:style:fix": "stylelint \"src/**/*.css\" --cache --fix",
    "fix:all": "npm run format && npm run lint:fix && npm run lint:style:fix",
    "validate": "cross-env NODE_OPTIONS='--pending-deprecation' npm run type-check && npm run lint && npm run lint:style && npm run format:check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build": "npm run type-check && vite build && node -e \"require('fs').copyFileSync('dist/index.html', 'dist/404.html')\"",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --cache --fix",
      "prettier --write --cache"
    ],
    "*.css": [
      "stylelint --cache --fix",
      "prettier --write --cache"
    ],
    "*.{json,md}": [
      "prettier --write --cache"
    ]
  },
  "engines": {
    "node": "22.22.1"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.3.2",
    "firebase": "12.10.0",
    "lucide-react": "0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "7.13.1",
    "tailwindcss": "^4.2.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/crypto-js": "4.2.2",
    "@types/jest": "30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "cross-env": "10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "17.4.0",
    "jsdom": "28.1.0",
    "lint-staged": "16.3.2",
    "msw": "2.12.10",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "4.0.18"
  }
}
